              },
              "ClinicalWarningCode": "CW999",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "CAUTION: Exterior of syringe or vial is not sterile. Wipe down syringe before use."
                }
              ]
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW999",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "CAUTION: OriGen has validated the interconnectability of VSV spikes on the CryoPur vials. The connection to luers on other medical devices must be validated by the user."
                }
              ]
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW032"
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW009"
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW999",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "WARNING: Wash out cryoprotectants before patient administration."
                }
              ]
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW999",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "Not for Injection or IV use. DMSO should be removed from cell product prior to administration to patient. Dose-dependent clinical risks have been reported with the infusion of DMSO including nausea, vomiting, cardiac symptoms, transient hypertension or hypotension, anaphylaxis, diarrhea, flushing, fever, chills, dyspnea, vasodilatation, pulmonary or abdominal complaints, bradycardia, encephalopathy, and seizures."
                }
              ]
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW999",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "Toxic: Heat is generated when pure DMSO is mixed with water. Do not add pure DMSO directly to cell product."
                }
              ]
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW999",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "Aggressive: DMSO is a highly polar organic solvent and is aggressive against many common plastics (ABS, PVC, PC, etc). Degradation of your bag and tubing may occur, and unwanted byproducts may be released into the sample."
                }
              ]
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW999",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "CAUTION: DMSO may be toxic to cells if used in high concentrations and if cells are exposed to DMSO for prolonged periods. Stem cells are usually cryopreserved in a solution containing 1.6 molal (10% v/v) DMSO. Concentrations above or below this have been reported to have lower cell viability."
                }
              ]
            }
          ]
        }
