              },
              "ClinicalWarningCode": "CW001",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "WARNING: Resterilization may damage the product. Re-use may cause contamination or viral transmission between cells."
                }
              ]
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW007"
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW032"
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW010",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "NOTE: All personnel should read these instructions before using the device. Always follow your institution’s protocols. Electronic IFUs may be accessed at: ifu.origen.com"
                }
              ]
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW999",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "CAUTION: Wash out cryoprotectants before patient administration."
                }
              ]
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW999",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "CAUTION: Use caution when handling the bag to prevent breakage. When the bag contents are frozen, it is much easier to damage the bag through impact."
                }
              ]
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW999",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "CAUTION: Some plastics have varying degrees of resistance to 100% DMSO. If using DMSO, dilute to less than 60% concentration before use."
                }
              ]
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW999",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "CAUTION: OriGen has validated that luers on the CryoStore bags are interconnectable to luers provided on other OriGen medical devices. The connection to other luers must be validated by the user."
                }
              ]
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW999",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "WARNING: Always debubble. Large air bubbles present during freezing may expand rapidly during thawing and could cause localized pressure to break the bag."
                }
              ]
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW999",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "CAUTION: The donor tube should be sealed below the spike ports to protect from potential impact while frozen."
                }
              ]
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW999",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "WARNING: For Multi-Chamber and FLEX Bags, carefully place the seal and cut between the chambers to avoid puncturing adjacent chambers."
                }
              ]
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW999",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "CAUTION: Freezing and solidification of the contents make the CryoStore bag more susceptible to damage by impact. It is strongly suggested that the bag be placed in an OriGen Biomedical O-Wrap™ bag inside a rigid freezing cassette for storage. Handle carefully when frozen."
                }
              ]
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW999",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "WARNING: The use of cassettes during freezing is recommended. Cassettes should be appropriately sized so that the bag fits comfortably."
                }
              ]
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW999",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "Certain cells and cryoprotectants may expand during freezing causing bag breakage. Always validate your freezing protocol."
                }
              ]
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW999",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "CAUTION: Migration of liquid nitrogen into the bag during storage may cause the bag to burst during re-warming. During re-warming, liquid nitrogen will gasify much quicker than it can escape through the bag walls. Monitor the CryoStore carefully for swelling during re-warming."
                }
              ]
            }
          ]
        }
