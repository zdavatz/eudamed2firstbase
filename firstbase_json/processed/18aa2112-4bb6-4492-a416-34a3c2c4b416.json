          "ClinicalWarning": [
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW011",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "1. The test is intended for in vitro diagnostic use only. 2. This test is a rapid test used as an aid for diagnosis and all positive results must be confirmed using an appropriate test such as RIBA (Recombinant Immunoblotting Assay) or equivalent. 3. All specimens shall be treated as potentially infectious. 4. Gloves and protective clothing must be worn when handling specimens.Operate according o standard safety precautions when disposingbiohazardous materials. 5. Used test cassette must be decontaminated before being discarded. 6. DO NOT use expired reagents or test cassettes. 7. DO NOT interchange reagents among kits with different lot No. 8. Sample diluents contain sodium azide. Sodium Azide can react with copper and lead used in certain plumbing systems to form metal saltswhich are explosive. The quantities used in this kit are small. nevertheless when disposing of sodium azide containing materials. they should be flushed away with relatively large quantities of water toprevent metal azide building up in plumbing system."
                }
              ]
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW010",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "Please read this package insert carefully prior to use and strictly follow the instructions. Reliability of the assay cannot be guaranteed if there are any deviations from the instructions in this package insert"
                }
              ]
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW009",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "DO NOT reuse test cassettes and any disposable accessories. (test cassette, plastic dropper, Sample diluents, Disposable Safety Lancets.Disposable Swabs,desiccant)"
                }
              ]
            },
            {
              "ClinicalWarningAgencyCode": {
                "Value": "EUDAMED"
              },
              "ClinicalWarningCode": "CW007",
              "WarningsOrContraIndicationDescription": [
                {
                  "LanguageCode": "en",
                  "Value": "1. DO NOT use the Disposable Safety Lancets if the cap is already pulled off. 2. DO NOT use the test cassette if the foil pouch is damaged or broken. 3. DO NOT use the Disposable Swabs if the pouch is damaged."
                }
              ]
            }
          ]
        }
